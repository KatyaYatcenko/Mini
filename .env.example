# Скопіюй цей файл у .env і заповни своїми даними.
# Нічого з цього нікуди не надсилається, окрім офіційних API Telegram та OpenRouter.

# --- Telegram (отримати на https://my.telegram.org -> API Development Tools) ---
TG_API_ID=123456
TG_API_HASH=your_api_hash_here
TG_SESSION_NAME=assist_session

# --- OpenRouter (для генерації чернеток відповіді) ---
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Голосове озвучення чернетки (необов'язково) ---
TTS_ENABLED=true
